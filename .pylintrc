[MESSAGES CONTROL]
# Disable specific warnings that are acceptable in this codebase context:
# - broad-exception-caught: We catch general exceptions for graceful fallbacks
# - import-outside-toplevel: Used for lazy loading in auto-discovery system
disable=broad-exception-caught,import-outside-toplevel

[DESIGN]
# Maximum number of arguments for function / method
max-args=7

# Maximum number of locals for function / method body
max-locals=15

# Maximum number of return statements in function / method body
max-returns=6

# Maximum number of branch for function / method body
max-branches=12

# Maximum number of statements in function / method body
max-statements=50
